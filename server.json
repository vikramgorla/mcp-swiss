{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.vikramgorla/swiss",
  "title": "Switzerland MCP 🇨🇭",
  "description": "Swiss open data — 65 tools, zero API keys. Trains, weather, geodata, energy, statistics, SNB rates, recycling, news, voting, dams, hiking, real estate, traffic.",
  "repository": {
    "url": "https://github.com/vikramgorla/mcp-swiss",
    "source": "github"
  },
  "version": "0.3.2-dev",
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/vikramgorla/mcp-swiss/main/assets/icon.svg",
      "mimeType": "image/svg+xml"
    },
    {
      "src": "https://raw.githubusercontent.com/vikramgorla/mcp-swiss/main/assets/icon.png",
      "mimeType": "image/png",
      "sizes": [
        "256x256"
      ]
    }
  ],
  "packages": [
    {
      "registryType": "npm",
      "identifier": "mcp-swiss",
      "version": "0.3.2-dev",
      "runtimeHint": "npx",
      "transport": {
        "type": "stdio"
      }
    }
  ]
}
